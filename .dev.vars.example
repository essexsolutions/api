# Copy to `.dev.vars` for local `astro dev` / `wrangler dev`. Never commit `.dev.vars`.
# The Cloudflare Workers runtime reads local secrets from THIS file (`.dev.vars`),
# not from `.env`. In production these are set in Webflow Cloud → Environment
# Variables (mark as "secret").

# Airtable personal access token (airtable.com → Builder hub → Personal access tokens).
# Needs data.records:read on the "Essex Website" base. Used by the admin full-sync.
AIRTABLE_API_TOKEN=""

# Arbitrary strong random string you generate (e.g. `openssl rand -hex 32`):
ADMIN_SYNC_KEY=""           # sent as the x-admin-key header to /api/admin/sync

# Optional: override the origin allowed to call /api/contact-lookup
# ALLOWED_ORIGIN="https://essexsolutions.webflow.io"
