{
  "name": "essex-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Essex Solutions edge API on Webflow Cloud — server-side contact email lookup (replaces the Jetboost on-page collection list).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "astro check",
    "db:migrate:local": "wrangler d1 migrations apply essex-contacts --local",
    "db:migrate:remote": "wrangler d1 migrations apply essex-contacts --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.5.0",
    "astro": "^5.7.0",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20250109.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^6.0.3",
    "wrangler": "^3.99.0"
  }
}
